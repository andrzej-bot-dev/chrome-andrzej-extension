{
  "manifest_version": 3,
  "name": "Andrzej — OpenClaw for Chrome",
  "version": "0.1.0",
  "description": "Talk to your OpenClaw in Chrome's side panel and let it work on web pages: click, fill forms, navigate.",
  "minimum_chrome_version": "137",
  "action": {
    "default_title": "Open Andrzej (OpenClaw)"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options/options.html",
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "tabGroups",
    "scripting",
    "activeTab",
    "contextMenus",
    "alarms",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "commands": {
    "open-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Open Andrzej panel"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
